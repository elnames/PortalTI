{
  "name": "portalti-fullstack",
  "version": "1.0.0",
  "description": "PortalTI - Sistema Integral de Gestión de Activos",
  "private": true,
  "scripts": {
    "start": "npm run start:frontend",
    "start:frontend": "react-scripts start",
    "start:backend": "cd portalti-backend/PortalTi.Api && dotnet run",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "react-scripts build",
    "build:backend": "cd portalti-backend/PortalTi.Api && dotnet publish -c Release -o ./publish",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm run start:frontend\" \"npm run start:backend\"",
    "install:all": "npm install && cd portalti-backend/PortalTi.Api && dotnet restore"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.15",
    "@fullcalendar/daygrid": "^6.1.15",
    "@fullcalendar/interaction": "^6.1.15",
    "@fullcalendar/list": "^6.1.15",
    "@fullcalendar/react": "^6.1.15",
    "@fullcalendar/timegrid": "^6.1.15",
    "@fullcalendar/timeline": "^6.1.15",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "axios": "^1.7.2",
    "lucide-react": "^0.427.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.4.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "serve": "^14.2.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}